# -----------------------------
# Core app settings
# -----------------------------
PROJECT_NAME=BillSmart API
VERSION=1.0.0
API_V1_STR=/api/v1
DEBUG=false
RELOAD=false

# -----------------------------
# Database settings
# -----------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=billsmart_db

# -----------------------------
# Security settings
# -----------------------------
SECRET_KEY=replace-with-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# -----------------------------
# CORS/front-end settings
# -----------------------------
FRONTEND_URL=http://localhost:3000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------
# OAuth (optional)
# -----------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------
# Email (optional)
# -----------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=
EMAILS_FROM_NAME=BillSmart

EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=2

# Optional host port mapping for Docker compose
API_PORT=8000
DB_PORT=5432
